{
  "name": "@respan/instrumentation-openai-agents",
  "type": "module",
  "version": "1.0.1",
  "description": "Respan instrumentation plugin for OpenAI Agents SDK (OTEL pipeline)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": "Respan <team@respan.ai>",
  "license": "Apache-2.0",
