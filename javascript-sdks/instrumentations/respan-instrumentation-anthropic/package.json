{
  "name": "@respan/instrumentation-anthropic",
  "type": "module",
  "version": "1.1.2",
  "description": "Respan instrumentation plugin for Anthropic SDK",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": "Respan <team@respan.ai>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
